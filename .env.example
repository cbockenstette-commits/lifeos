# Postgres (used by docker-compose and Prisma)
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=lifeos
POSTGRES_DB=lifeos
POSTGRES_PORT=5432

# Prisma
DATABASE_URL="postgresql://lifeos:lifeos@127.0.0.1:5432/lifeos?schema=public"
DATABASE_URL_TEST="postgresql://lifeos:lifeos@127.0.0.1:5432/lifeos_test?schema=public"

# API
API_HOST=127.0.0.1
API_PORT=3000
NODE_ENV=development
